{
  "mcpServers": {
    "habanero": {
      "command": "./.venv/bin/python3",
      "args": ["./tools/pepper-mcp"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--headless",
        "--user-data-dir", "${HOME}/.habanero/chrome-profile"
      ]
    }
  }
}
